{
  "name": "nowo-tech/dashboard-menu-bundle",
  "description": "Assets build for Dashboard Menu Bundle (TypeScript)",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "VITE_ENTRY=dashboard vite build && VITE_ENTRY=stimulus-live vite build",
    "dev": "VITE_ENTRY=dashboard vite build --watch",
    "watch": "VITE_ENTRY=dashboard vite build --watch",
    "build:dashboard": "VITE_ENTRY=dashboard vite build",
    "build:stimulus-live": "VITE_ENTRY=stimulus-live vite build"
  },
  "dependencies": {
    "sortablejs": "^1.15.6"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.8",
    "typescript": "^5.6.0",
    "vite": "^5.0.0"
  }
}
