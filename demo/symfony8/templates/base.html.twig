{% set _demo_domain = 'messages' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'demo.app_title'|trans({}, _demo_domain) }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --sidebar-width: 14rem;
            --aside-width: 12rem;
            --content-max-width: 52rem;
        }
        body { min-height: 100vh; display: flex; flex-direction: column; }
        .app-header {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
            box-shadow: 0 2px 8px rgba(0,0,0,.15);
        }
        .app-header .navbar-brand { color: #ecf0f1 !important; font-weight: 600; }
        .app-header .btn-outline-light:hover { background: rgba(255,255,255,.2); color: #fff; }
        .app-header .dropdown .btn { color: #ecf0f1; border-color: rgba(255,255,255,.4); }
        .app-header .dropdown .btn:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.6); color: #fff; }

        .app-layout { display: flex; flex: 1; }
        .app-sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            background: #f8f9fa;
            border-right: 1px solid #dee2e6;
            padding: 1.25rem 0;
        }
        .app-aside {
            width: var(--aside-width);
            min-width: var(--aside-width);
            background: #f8f9fa;
            border-left: 1px solid #dee2e6;
            padding: 1.25rem 0;
        }
        .app-main {
            flex: 1;
            min-width: 0;
            padding: 2rem 2.5rem;
            max-width: var(--content-max-width);
            margin: 0 auto;
        }
        .app-main h1 { font-size: 1.75rem; margin-bottom: 1rem; color: #2c3e50; }
        .app-main p { color: #495057; line-height: 1.6; }
        .app-main code { background: #f1f3f5; padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; }

        /* Sidebar / aside: menus (.dashboard-menu-tree is always present on the bundle tree) */
        .app-sidebar .dashboard-menu-tree,
        .app-aside .dashboard-menu-tree {
            list-style: none;
            padding: 0 0.75rem;
            margin: 0;
        }
        .app-sidebar .dashboard-menu-tree li,
        .app-aside .dashboard-menu-tree li { margin-bottom: 0.125rem; }
        .app-sidebar .dashboard-menu-tree a,
        .app-aside .dashboard-menu-tree a {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 0.75rem;
            color: #495057;
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.9375rem;
        }
        .app-sidebar .dashboard-menu-tree a .bi,
        .app-aside .dashboard-menu-tree a .bi { margin-right: 0.5rem; font-size: 1.1em; }
        .app-sidebar .dashboard-menu-tree a:hover,
        .app-aside .dashboard-menu-tree a:hover { background: #e9ecef; color: #212529; }
        .app-sidebar .dashboard-menu-tree a.active,
        .app-aside .dashboard-menu-tree a.active { background: #0d6efd; color: #fff; }
        .app-sidebar .dashboard-menu-tree .navigation-header,
        .app-aside .dashboard-menu-tree .navigation-header {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6c757d;
            padding: 0.75rem 0.75rem 0.35rem;
            font-weight: 600;
        }
        /* Section heading uses <a> for DOM parity with link rows; keep visual “text”, not interactive link chrome. */
        .app-sidebar .dashboard-menu-tree a.menu-section-label-link,
        .app-aside .dashboard-menu-tree a.menu-section-label-link {
            cursor: default;
            pointer-events: none;
        }
        .app-sidebar .dashboard-menu-tree a.menu-section-label-link:hover,
        .app-aside .dashboard-menu-tree a.menu-section-label-link:hover {
            background: transparent;
            color: #6c757d;
        }
        .app-sidebar .dashboard-menu-tree .menu-divider hr,
        .app-aside .dashboard-menu-tree .menu-divider hr {
            margin: 0.5rem 0.75rem;
            border: 0;
            border-top: 1px solid #dee2e6;
        }
        /* Nested levels: indentation and left border */
        .app-sidebar .dashboard-menu-tree ul,
        .app-aside .dashboard-menu-tree ul {
            list-style: none;
            padding-left: 1rem;
            margin: 0.25rem 0 0.5rem 0;
            border-left: 2px solid #dee2e6;
        }
        .sidebar-title, .aside-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6c757d;
            padding: 0 0.75rem 0.75rem;
            font-weight: 700;
        }
        .sidebar-admin a { font-size: 0.9375rem; color: #495057; }
        .sidebar-admin a:hover { background: #e9ecef; color: #212529; }
        .menu-nested-toggle { color: #6c757d; text-decoration: none; font-size: 0.75rem; min-width: 1.5rem; line-height: 1; }
        .menu-nested-toggle:hover { color: #0d6efd; }
        .menu-nested-toggle-icon { display: inline-flex; align-items: center; transition: transform 0.2s ease; }
        .menu-nested-toggle-icon svg { display: block; color: inherit; }
        .menu-nested-toggle[aria-expanded="true"] .menu-nested-toggle-icon { transform: rotate(-180deg); }
        .app-sidebar .dashboard-menu-tree .collapse ul,
        .app-aside .dashboard-menu-tree .collapse ul { padding-left: 1rem; margin: 0.25rem 0 0.5rem 0; border-left: 2px solid #dee2e6; }

        /* Footer */
        .app-footer {
            background: #f8f9fa;
            border-top: 1px solid #dee2e6;
            padding: 1rem 2rem;
            margin-top: auto;
        }
        .app-footer .dashboard-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 1.25rem;
            justify-content: center;
        }
        .app-footer .dashboard-menu a {
            color: #6c757d;
            text-decoration: none;
            font-size: 0.875rem;
        }
        .app-footer .dashboard-menu a:hover { color: #0d6efd; }
        .app-footer .dashboard-menu a .bi { margin-right: 0.35rem; }

        /* Header dropdown: force styles when the menu has no Bootstrap classes */
        .app-header .dropdown-menu .dashboard-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            min-width: 10rem;
        }
        .app-header .dropdown-menu .dashboard-menu a {
            display: block;
            padding: 0.5rem 1rem;
            color: #212529;
            text-decoration: none;
        }
        .app-header .dropdown-menu .dashboard-menu a { display: inline-flex; align-items: center; }
        .app-header .dropdown-menu .dashboard-menu a:hover { background: #f8f9fa; }
        .app-header .dropdown-menu .dashboard-menu a .bi { margin-right: 0.35rem; }
        .app-header .dropdown .navigation-header { padding: 0.35rem 1rem; font-size: 0.75rem; }
        .app-header .dropdown .menu-divider hr { margin: 0.25rem 0; }
    </style>
</head>
<body>
    <header class="navbar navbar-expand-lg app-header">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="{{ path('app_home') }}">{{ 'demo.app_title_version'|trans({}, _demo_domain) }}</a>
            <div class="d-flex align-items-center gap-1">
                {% set localeTree = dashboard_menu_tree('locale_switcher') %}
                {% set _localeConfig = dashboard_menu_config('locale_switcher')|default({}) %}
                {% set localeConfig = _localeConfig|merge({ classes: (_localeConfig.classes|default({}))|merge({ menu: 'nav gap-1', link: 'btn btn-sm btn-outline-light' }) }) %}
                {% if localeTree is not empty %}
                    <nav class="d-flex align-items-center" aria-label="{{ 'demo.language'|trans({}, _demo_domain) }}">
                        {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: localeTree, menuCode: 'locale_switcher', menuConfig: localeConfig } %}
                    </nav>
                {% endif %}
                <a href="{{ path('nowo_dashboard_menu_dashboard_index') }}" class="btn btn-sm btn-outline-light">{{ 'demo.edit_menus'|trans({}, _demo_domain) }}</a>
                <div class="dropdown">
                    <button class="btn btn-outline-light dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">{{ 'demo.user_menu'|trans({}, _demo_domain) }}</button>
                    {% set dropdownTree = dashboard_menu_tree('dropdown') %}
                    {% set dropdownConfig = dashboard_menu_config('dropdown') %}
                    {% set dropdownConfig = dropdownConfig|default({})|merge({ classes: (dropdownConfig.classes|default({}))|merge({ menu: 'dropdown-menu dropdown-menu-end', link: 'dropdown-item', item: '', children: '' }) }) %}
                    {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: dropdownTree, menuCode: 'dropdown', menuConfig: dropdownConfig } %}
                </div>
            </div>
        </div>
    </header>

    <div class="app-layout">
        <nav class="app-sidebar" aria-label="{{ 'demo.sidebar'|trans({}, _demo_domain) }}">
            <div class="sidebar-title">{{ 'demo.sidebar'|trans({}, _demo_domain) }}</div>
            {% set sidebarTree = dashboard_menu_tree('sidebar') %}
            {% set sidebarConfig = dashboard_menu_config('sidebar') %}
            {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: sidebarTree, menuCode: 'sidebar', menuConfig: sidebarConfig } %}
            <div class="sidebar-admin mt-3 pt-3 border-top">
                <div class="sidebar-title">{{ 'demo.admin'|trans({}, _demo_domain) }}</div>
                <a href="{{ path('nowo_dashboard_menu_dashboard_index') }}" class="d-flex align-items-center px-3 py-2 text-decoration-none text-dark rounded">
                    <i class="bi bi-gear me-2" aria-hidden="true"></i>
                    <span>{{ 'demo.manage_menus'|trans({}, _demo_domain) }}</span>
                </a>
            </div>
        </nav>
        <main class="app-main">{% block body %}{% endblock %}</main>
        <aside class="app-aside" aria-label="{{ 'demo.aside'|trans({}, _demo_domain) }}">
            <div class="aside-title">{{ 'demo.aside'|trans({}, _demo_domain) }}</div>
            {% set asideTree = dashboard_menu_tree('aside') %}
            {% set asideConfig = dashboard_menu_config('aside') %}
            {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: asideTree, menuCode: 'aside', menuConfig: asideConfig } %}
        </aside>
    </div>

    <footer class="app-footer">
        {% set footerTree = dashboard_menu_tree('footer') %}
        {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: footerTree, menuCode: 'footer' } %}
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        {# Only replace legacy icons (without ":"); heroicons-outline:icon types are already rendered as SVG by ux_icon. #}
        document.querySelectorAll('.menu-item-icon').forEach(function(span) {
            var name = span.getAttribute('data-icon');
            if (name && name.indexOf(':') === -1) {
                var i = document.createElement('i');
                i.className = 'bi bi-' + name;
                i.setAttribute('aria-hidden', 'true');
                // Transfer the inline style (e.g. font-size) from the legacy <span> to the injected <i>.
                // This is required for `nowo_dashboard_menu.dashboard.icon_size`.
                var style = span.getAttribute('style');
                if (style) {
                    i.setAttribute('style', style);
                }
                span.parentNode.insertBefore(i, span);
                span.remove();
            }
        });
    </script>
</body>
</html>
