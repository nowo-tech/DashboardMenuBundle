# Dashboard Menu Bundle Demo - Symfony 8
# Copy to .env and adjust if needed. Do not commit .env.
# cp .env.example .env

# Symfony application
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_this_secret_key_to_a_random_value

# VarDumper server (for dump() in browser/CLI). Run: php bin/console server:dump
VAR_DUMPER_SERVER=127.0.0.1:9912

# Web server port (docker-compose mapping host:container)
PORT=8011

# DEFAULT_URI: base URL for CLI routing and documentation (must match PORT above).
DEFAULT_URI=http://localhost:8011

# MySQL – used by docker-compose to build DATABASE_URL in the container
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=dashboard_menu_demo
MYSQL_USER=demo_user
MYSQL_PASSWORD=password

# DATABASE_URL (optional in .env): docker-compose sets mysql://…@mysql:3306/… when containers run.
# DATABASE_URL="mysql://demo_user:password@mysql:3306/dashboard_menu_demo?serverVersion=8.0&charset=utf8mb4"
