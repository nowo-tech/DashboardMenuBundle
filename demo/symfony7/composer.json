{
    "name": "nowo-tech/dashboard-menu-demo-symfony7",
    "description": "Demo for Dashboard Menu Bundle - Symfony 7",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "doctrine/doctrine-bundle": "^2.11",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^2.17 || ^3.0",
        "nowo-tech/dashboard-menu-bundle": "@dev",
        "nowo-tech/icon-selector-bundle": "v1.0.4",
        "nowo-tech/twig-inspector-bundle": "v1.0.5",
        "pentatrion/vite-bundle": "^8.0",
        "symfony/asset": "^7.0",
        "symfony/console": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/flex": "^2.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "7.0.*",
        "symfony/runtime": "^7.0",
        "symfony/security-bundle": "^7.0",
        "symfony/stimulus-bundle": "^2.0",
        "symfony/translation": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/ux-autocomplete": "^2.33",
        "symfony/validator": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "7.0.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/dashboard-menu-bundle"
        }
    ],
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.2",
        "nowo-tech/twig-inspector-bundle": "v1.0.5",
        "symfony/debug-bundle": "^7.0",
        "symfony/var-dumper": "^7.0",
        "symfony/web-profiler-bundle": "^7.0"
    }
}
