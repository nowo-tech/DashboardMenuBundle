{% set _demo_domain = 'messages' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'demo.app_title'|trans({}, _demo_domain) }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .navigation-header { font-size: .75rem; text-transform: uppercase; color: var(--bs-secondary); padding: 0.25rem 0; }
        .menu-divider hr { margin: 0.25rem 0; border: 0; border-top: 1px solid rgba(0,0,0,.1); }
        .dropdown-menu .menu-divider { list-style: none; }
        .dropdown-menu .menu-divider hr { margin: 0.5rem 0; }
        .dropdown-menu .menu-section .navigation-header { padding: 0.25rem 0.5rem; font-size: .875rem; color: var(--bs-secondary); }
        /* Menu hierarchy: nested levels with indentation */
        .dashboard-menu-tree { list-style: none; padding-left: 0; margin: 0; }
        .dashboard-menu-tree ul { list-style: none; padding-left: 1rem; margin: 0.25rem 0 0.5rem 0; border-left: 2px solid rgba(0,0,0,.12); }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path('app_home') }}">{{ 'demo.app_title_version'|trans({}, _demo_domain) }}</a>
            <div class="d-flex align-items-center gap-2">
                {% set localeTree = dashboard_menu_tree('locale_switcher') %}
                {% set _localeConfig = dashboard_menu_config('locale_switcher')|default({}) %}
                {% set localeConfig = _localeConfig|merge({ classes: (_localeConfig.classes|default({}))|merge({ menu: 'nav gap-1', link: 'btn btn-sm btn-outline-secondary' }) }) %}
                {% if localeTree is not empty %}
                    <nav class="d-flex align-items-center" aria-label="{{ 'demo.language'|trans({}, _demo_domain) }}">
                        {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: localeTree, menuCode: 'locale_switcher', menuConfig: localeConfig } %}
                    </nav>
                {% endif %}
                <a href="{{ path('nowo_dashboard_menu_dashboard_index') }}" class="btn btn-sm btn-outline-secondary">{{ 'demo.edit_menus'|trans({}, _demo_domain) }}</a>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">{{ 'demo.user_menu'|trans({}, _demo_domain) }}</button>
                    {% set dropdownTree = dashboard_menu_tree('dropdown') %}
                    {% set dropdownConfig = dashboard_menu_config('dropdown') %}
                    {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: dropdownTree, menuCode: 'dropdown', menuConfig: dropdownConfig } %}
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid flex-grow-1">
        <div class="row h-100">
            <nav class="col-md-2 col-lg-2 d-md-block bg-light border-end py-3" aria-label="{{ 'demo.sidebar'|trans({}, _demo_domain) }}">
                <h6 class="px-3 text-muted small text-uppercase">{{ 'demo.sidebar'|trans({}, _demo_domain) }}</h6>
                {% set sidebarTree = dashboard_menu_tree('sidebar') %}
                {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: sidebarTree, menuCode: 'sidebar' } %}
            </nav>
            <main class="col-md-8 col-lg-8 py-4">{% block body %}{% endblock %}</main>
            <aside class="col-md-2 col-lg-2 d-md-block bg-light border-start py-3" aria-label="{{ 'demo.aside'|trans({}, _demo_domain) }}">
                <h6 class="px-3 text-muted small text-uppercase">{{ 'demo.aside'|trans({}, _demo_domain) }}</h6>
                {% set asideTree = dashboard_menu_tree('aside') %}
                {% set asideConfig = dashboard_menu_config('aside') %}
                {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: asideTree, menuCode: 'aside', menuConfig: asideConfig } %}
            </aside>
        </div>
    </div>

    <footer class="py-3 mt-auto bg-light border-top">
        <div class="container-fluid">
            {% set footerTree = dashboard_menu_tree('footer') %}
            {% include '@NowoDashboardMenuBundle/menu.html.twig' with { menuTree: footerTree, menuCode: 'footer' } %}
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
