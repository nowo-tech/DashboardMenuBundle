{# Renders a dashboard menu tree. Optional: pass menuConfig or use dashboard_menu_config(menuCode). #}
{# Usage: {% set tree = dashboard_menu_tree('sidebar') %} {% set menuConfig = menuConfig|default(dashboard_menu_config('sidebar')) %} {{ include('@NowoDashboardMenuBundle/menu.html.twig', { menuTree: tree, menuCode: menuCode|default('sidebar'), menuConfig: menuConfig }) }} #}
{% macro render_node(node, menuConfig, depth, idPrefix, parentItemType) %}
    {# Macro arguments and defaults (idPrefix scopes collapse IDs; parentItemType drives section-child styling). #}
    {% set idPrefix = idPrefix|default('menu') %}
    {% set parentItemType = parentItemType|default('') %}
    {% set item = node.item %}
    {% set itemType = item.itemType|default('link') %}
    {# Respect depth_limit: stop adding deeper nested children when max depth is reached. #}
    {% set depthLimit = menuConfig.depth_limit %}
    {% set maxReached = depthLimit is not null and depth >= depthLimit %}
    {# CSS classes from config: items/links; children of a section can use dedicated section_child_* classes. #}
    {% set baseItemClasses = menuConfig.classes.item is defined ? menuConfig.classes.item : '' %}
    {% set sectionChildItemClasses = menuConfig.classes.section_child_item is defined ? menuConfig.classes.section_child_item : '' %}
    {% set itemClasses = parentItemType == 'section' and sectionChildItemClasses|trim != '' ? sectionChildItemClasses : baseItemClasses %}
    {% set baseLinkClasses = menuConfig.classes.link is defined ? menuConfig.classes.link : '' %}
    {% set sectionChildLinkClasses = menuConfig.classes.section_child_link is defined ? menuConfig.classes.section_child_link : '' %}
    {% set linkClasses = parentItemType == 'section' and sectionChildLinkClasses|trim != '' ? sectionChildLinkClasses : baseLinkClasses %}
    {% set childrenClasses = menuConfig.classes.children is defined ? menuConfig.classes.children : '' %}
    {% set sectionDirectChildrenClasses = menuConfig.classes.section_children is defined ? menuConfig.classes.section_children : '' %}
    {% set sectionLabelClasses = menuConfig.classes.section_label is defined ? menuConfig.classes.section_label : 'navigation-header' %}
    {% set sectionItemClasses = menuConfig.classes.section is defined ? menuConfig.classes.section : 'menu-section' %}
    {% set dividerItemClasses = menuConfig.classes.divider is defined ? menuConfig.classes.divider : 'menu-divider' %}
    {# Icons: only for link/service when icons are enabled in config. #}
    {% set iconName = item.icon|default(menuConfig.icons.default) %}
    {% set showIcon = menuConfig.icons.enabled and iconName is not empty and (itemType == 'link' or itemType == 'service') %}
    {# State CSS tokens (current route, branch open, expand/collapse) from config with sensible defaults. #}
    {% set classCurrent = menuConfig.classes.class_current is defined ? menuConfig.classes.class_current : 'active' %}
    {% set classBranchExpanded = menuConfig.classes.class_branch_expanded is defined ? menuConfig.classes.class_branch_expanded : 'active-branch' %}
    {% set classHasChildren = menuConfig.classes.class_has_children is defined ? menuConfig.classes.class_has_children : '' %}
    {% set classExpanded = menuConfig.classes.class_expanded is defined ? menuConfig.classes.class_expanded : '' %}
    {% set classCollapsed = menuConfig.classes.class_collapsed is defined ? menuConfig.classes.class_collapsed : '' %}
    {% set isCurrent = node.isCurrent|default(false) %}
    {% set hasCurrentInBranch = node.hasCurrentInBranch|default(false) %}
    {# Nested collapsible: global flag plus whether sections inherit collapsible children by default. #}
    {% set nestedCollapsible = menuConfig.nested_collapsible|default(false) %}
    {% set nestedCollapsibleSections = menuConfig.nested_collapsible_sections|default(true) %}
    {% set menuDefaultSectionCollapsible = nestedCollapsible and nestedCollapsibleSections %}
    {% set hasChildren = not maxReached and node.children|length > 0 %}
    {# Per-section override: null falls back to menu default; non-section nodes are never "section collapsible". #}
    {% if itemType == 'section' %}
        {% set sectionChildrenCollapsible = item.sectionCollapsible is null ? menuDefaultSectionCollapsible : item.sectionCollapsible %}
    {% else %}
        {% set sectionChildrenCollapsible = false %}
    {% endif %}
    {% set useNestedCollapsibleForChildren = (itemType == 'section' and sectionChildrenCollapsible) or (itemType != 'section' and nestedCollapsible) %}
    {# Section with sectionCollapsible explicitly false: render children as sibling <li> under the parent <ul>, not in a nested sub-list. #}
    {% set flattenSectionChildren = itemType == 'section' and item.sectionCollapsible is same as(false) and hasChildren %}
    {# Extra <li> classes reflecting branch state (current in subtree, has children, expanded vs collapsed). #}
    {% set liExtra = (hasCurrentInBranch ? classBranchExpanded : '') %}
    {% set liExtra = liExtra ~ (hasChildren and classHasChildren is not empty ? ' ' ~ classHasChildren : '') %}
    {% set liExtra = liExtra ~ (hasChildren and hasCurrentInBranch and classExpanded is not empty ? ' ' ~ classExpanded : '') %}
    {% set liExtra = liExtra ~ (hasChildren and not hasCurrentInBranch and classCollapsed is not empty ? ' ' ~ classCollapsed : '') %}
    {% set liExtra = liExtra|trim %}
    {# Final <li> / <a> class strings (section + divider modifiers, then state extras; link gets current marker). #}
    {% set liClass = (itemClasses ~ (itemType == 'section' and sectionItemClasses is not empty ? ' ' ~ sectionItemClasses : '') ~ (itemType == 'divider' and dividerItemClasses is not empty ? ' ' ~ dividerItemClasses : '') ~ (liExtra is not empty ? ' ' ~ liExtra : ''))|trim %}
    {% set aClass = (linkClasses ~ (isCurrent and classCurrent is not empty ? ' ' ~ classCurrent : ''))|trim %}
    {% set collapseId = idPrefix ~ '-item-' ~ item.id %}
    <li{% if liClass %} class="{{ liClass }}"{% endif %}>
        {% if itemType == 'divider' %}
            <hr>
        {% elseif itemType == 'section' %}
            {# Collapsible section with children: same DOM pattern as link rows (<a> + toggle), label styled as heading via sectionLabelClasses + menu-section-label-link. #}
            {% if useNestedCollapsibleForChildren and hasChildren %}
                {% if menuConfig.item_span_active|default(false) %}
                    <span{% if menuConfig.item_span_class is not empty %} class="{{ menuConfig.item_span_class }}"{% endif %}>
                {% endif %}
                <a href="#" class="{{ sectionLabelClasses }} menu-section-label-link min-w-0 d-inline-flex align-items-center text-decoration-none" tabindex="-1">{{ item.label }}</a>
                <button type="button" class="btn btn-link btn-sm p-0 ms-1 menu-nested-toggle" data-bs-toggle="collapse" data-bs-target="#{{ collapseId }}" aria-expanded="true" aria-controls="{{ collapseId }}" title="{{ 'dashboard.toggle'|trans({}, 'NowoDashboardMenuBundle') }}">
                    <span class="menu-nested-toggle-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2.5 5.5L8 11l5.5-5.5H2.5z"/></svg></span>
                </button>
                {% if menuConfig.item_span_active|default(false) %}
                    </span>
                {% endif %}
            {% else %}
                <span class="{{ sectionLabelClasses }}">{{ item.label }}</span>
            {% endif %}
        {% else %}
            {% if menuConfig.item_span_active|default(false) %}
                <span{% if menuConfig.item_span_class is not empty %} class="{{ menuConfig.item_span_class }}"{% endif %}>
            {% endif %}
                <a href="{{ dashboard_menu_href(item) }}"{% if aClass %} class="{{ aClass }}"{% endif %}{% if item.targetBlank %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    {% if showIcon %}
                        {% if ':' in iconName %}
                            {% set iconSize = menuConfig.icon_size|default('1em') %}
                            {{ ux_icon(iconName, { class: 'menu-item-icon-svg', style: 'height:' ~ iconSize ~ '; width:' ~ iconSize ~ ';', 'aria-hidden': true }) }}
                        {% else %}
                            {% set iconSize = menuConfig.icon_size|default('1em') %}
                            <span class="menu-item-icon" data-icon="{{ iconName }}" aria-hidden="true" style="font-size: {{ iconSize }}; line-height: 1; display: inline-flex; align-items: center; justify-content: center;"></span>
                        {% endif %}
                    {% endif %}
                    {{ item.label }}
                </a>
                {% if useNestedCollapsibleForChildren and hasChildren %}
                    <button type="button" class="btn btn-link btn-sm p-0 ms-1 menu-nested-toggle" data-bs-toggle="collapse" data-bs-target="#{{ collapseId }}" aria-expanded="true" aria-controls="{{ collapseId }}" title="{{ 'dashboard.toggle'|trans({}, 'NowoDashboardMenuBundle') }}">
                        <span class="menu-nested-toggle-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2.5 5.5L8 11l5.5-5.5H2.5z"/></svg></span>
                    </button>
                {% endif %}
            {% if menuConfig.item_span_active|default(false) %}
                </span>
            {% endif %}
        {% endif %}
        {% if hasChildren and not flattenSectionChildren %}
            {% set childUlClasses = itemType == 'section' and sectionDirectChildrenClasses|trim != '' ? sectionDirectChildrenClasses : childrenClasses %}
            {% if useNestedCollapsibleForChildren %}
                <div id="{{ collapseId }}" class="collapse show">
                    <ul{% if childUlClasses %} class="{{ childUlClasses }}"{% endif %}>
                        {% for child in node.children %}
                            {{ _self.render_node(child, menuConfig, depth + 1, idPrefix, itemType) }}
                        {% endfor %}
                    </ul>
                </div>
            {% else %}
                <ul{% if childUlClasses %} class="{{ childUlClasses }}"{% endif %}>
                    {% for child in node.children %}
                        {{ _self.render_node(child, menuConfig, depth + 1, idPrefix, itemType) }}
                    {% endfor %}
                </ul>
            {% endif %}
        {% endif %}
    </li>
    {% if hasChildren and flattenSectionChildren %}
        {% for child in node.children %}
            {{ _self.render_node(child, menuConfig, depth + 1, idPrefix, '') }}
        {% endfor %}
    {% endif %}
{% endmacro %}

{% if menuTree is defined and menuTree|length > 0 %}
{% set menuConfig = menuConfig|default(dashboard_menu_config(menuCode|default('main'))) %}
{% set code = menuCode|default('main') %}
{% set rootClasses = menuConfig.classes.menu is defined ? menuConfig.classes.menu : 'dashboard-menu' %}
{% set collapsible = menuConfig.collapsible|default(false) %}
{% set collapseId = 'dashboard-menu-' ~ code %}
{% set expanded = collapsible ? (menuConfig.collapsible_expanded|default(true)) : true %}
{% if collapsible %}
<div class="dashboard-menu-collapsible">
    <button type="button" class="dashboard-menu-toggle btn btn-link text-start w-100 d-flex align-items-center justify-content-between" data-bs-toggle="collapse" data-bs-target="#{{ collapseId }}" aria-expanded="{{ expanded ? 'true' : 'false' }}" aria-controls="{{ collapseId }}">
        <span>{{ menuConfig.menu_name|default(code)|trans({}, 'NowoDashboardMenuBundle') }}</span>
        <span class="dashboard-menu-toggle-icon" aria-hidden="true"></span>
    </button>
    <div id="{{ collapseId }}" class="collapse{{ expanded ? ' show' : '' }}">
{% endif %}
{% set menuAttrs = menuConfig.context is defined and menuConfig.context is iterable ? menuConfig.context : [] %}
<ul{% if menuConfig.ul_id is not null and menuConfig.ul_id != '' %} id="{{ menuConfig.ul_id|e('html_attr') }}"{% endif %} class="{{ rootClasses }} {{ code }} dashboard-menu-tree"{% for key, value in menuAttrs %} {{ key }}="{{ value is same as(true) ? 'true' : (value is same as(false) ? 'false' : value) }}"{% endfor %}>
    {% for node in menuTree %}
        {{ _self.render_node(node, menuConfig, 1, code, '') }}
    {% endfor %}
</ul>
{% if collapsible %}
    </div>
</div>
{% endif %}
{% endif %}
