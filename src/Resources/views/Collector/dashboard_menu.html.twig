{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% set menus = collector.menus|default([]) %}
    {% set count = menus|length %}
    {% set query_count = collector.menuQueryCount %}
    {% set icon %}
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="img" aria-label="Dashboard menus"><title>Dashboard menus</title><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
        <span class="sf-toolbar-value">{{ count }}</span>
        <span class="sf-toolbar-label">menu{{ count != 1 ? 's' : '' }}</span>
        {% if query_count is not null %}
            <span class="sf-toolbar-info-piece-additional-detail">
                <span class="sf-toolbar-label">·</span>
                <span class="sf-toolbar-value">{{ query_count }}</span>
                <span class="sf-toolbar-label">queries</span>
            </span>
        {% endif %}
    {% endset %}
    {% set text %}
        <div class="sf-toolbar-info-group">
            <div class="sf-toolbar-info-piece">
                <b>Menus on page</b>
                <span>{{ count }}</span>
            </div>
            {% if query_count is not null %}
                <div class="sf-toolbar-info-piece">
                    <b>Menu-related queries</b>
                    <span>{{ query_count }}</span>
                </div>
            {% endif %}
        </div>
    {% endset %}
    {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url, icon: icon, text: text }) }}
{% endblock %}

{% block menu %}
    <span class="label">
        <span class="icon">{{ source('@NowoDashboardMenuBundle/Collector/icon.svg') }}</span>
        <strong>Dashboard menus</strong>
        {% set count = collector.menus|default([])|length %}
        <span class="count">{{ count }}</span>
    </span>
{% endblock %}

{% block panel %}
    {% set menus = collector.menus|default([]) %}
    {% set query_count = collector.menuQueryCount %}
    {% set cache = collector.cacheConfig %}
    {% set connection = collector.connectionName %}
    {% set table_prefix = collector.tablePrefix %}
    {% set locales = collector.locales %}
    {% set default_locale = collector.defaultLocale %}
    {% set icon_map = collector.iconLibraryPrefixMap %}
    {% set permission_checkers = collector.permissionCheckerChoices %}
    {% set permission_checks = collector.permissionChecks %}
    {% set bundle_config = collector.bundleConfig %}

    <div class="sf-tabs">
        <div class="tab" id="nowo-dm-tab-menus">
            <h3 class="tab-title">
                Menus <span class="badge">{{ menus|length }}</span>
            </h3>
            <div class="tab-content">
                <h2>Dashboard menus on this page</h2>
                {% if query_count is not null %}
                    <div class="metrics">
                        <div class="metric">
                            <span class="value">{{ query_count }}</span>
                            <span class="label">DB queries (dashboard_menu* tables)</span>
                        </div>
                    </div>
                {% endif %}

                {% if menus is empty %}
                    <p>No menus were rendered (no <code>dashboard_menu_tree()</code> calls).</p>
                {% else %}
                    <table class="sf-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Context (resolved)</th>
                                <th>Root items</th>
                                <th>Queries</th>
                                <th>Items tree</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for m in menus %}
                                <tr>
                                    <td><code>{{ m.code }}</code></td>
                                    <td>
                                        {% if m.resolved_context is defined and m.resolved_context is not null and m.resolved_context is not empty %}
                                            <code>{{ m.resolved_context is iterable ? m.resolved_context|json_encode(320) : m.resolved_context }}</code>
                                        {% elseif m.context_sets is defined and m.context_sets is iterable and m.context_sets is not empty %}
                                            <span class="text-muted">context sets: {{ m.context_sets|length }} option(s)</span>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ m.root_count }}</td>
                                    <td>
                                        {% if m.query_count is defined and m.query_count is not null %}
                                            <span class="sf-toolbar-status sf-toolbar-status-{{ m.query_count > 10 ? 'red' : (m.query_count > 3 ? 'yellow' : 'green') }}">{{ m.query_count }}</span>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ _self.tree_summary(m.items_summary) }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>

        <div class="tab" id="nowo-dm-tab-configuration">
            <h3 class="tab-title">Configuration</h3>
            <div class="tab-content">
                <h2>Bundle configuration</h2>

                <div class="metrics">
                    <div class="metric">
                        <span class="value"><code>{{ connection ?? 'default' }}</code></span>
                        <span class="label">Doctrine connection</span>
                    </div>
                    <div class="metric">
                        <span class="value"><code>{{ table_prefix is not empty ? table_prefix : '∅' }}</code></span>
                        <span class="label">Table prefix</span>
                    </div>
                    <div class="metric">
                        <span class="value">{{ cache.ttl ?? '∅' }}</span>
                        <span class="label">Cache TTL (s)</span>
                    </div>
                    <div class="metric">
                        <span class="value"><code>{{ cache.pool ?? '∅' }}</code></span>
                        <span class="label">Cache pool</span>
                    </div>
                </div>

                <h3>Locales</h3>
                <p>
                    <strong>Enabled locales:</strong>
                    {% if locales is not empty %}
                        {{ locales|join(', ') }}
                    {% else %}
                        <span class="text-muted">none (uses application defaults)</span>
                    {% endif %}
                    <br>
                    <strong>Default locale:</strong>
                    <code>{{ default_locale ?? '∅' }}</code>
                </p>

                <h3>Icon library prefix map</h3>
                {% if icon_map is empty %}
                    <p class="text-muted">No icon prefix map configured (icons are used as-is).</p>
                {% else %}
                    <table class="sf-table">
                        <thead>
                            <tr>
                                <th>Library</th>
                                <th>Prefix</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for lib, prefix in icon_map %}
                                <tr>
                                    <td><code>{{ lib }}</code></td>
                                    <td><code>{{ prefix }}</code></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}

                <h3>Permission checker services</h3>
                {% if permission_checkers is empty %}
                    <p class="text-muted">No tagged permission checker services were found.</p>
                {% else %}
                    <table class="sf-table">
                        <thead>
                            <tr>
                                <th>Service id</th>
                                <th>Label (form choice)</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for id, label in permission_checkers %}
                                <tr>
                                    <td><code>{{ id }}</code></td>
                                    <td>{{ label }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}

                <h3>Effective config snapshot</h3>
                <table class="sf-table">
                    <thead>
                        <tr>
                            <th>Key</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>project</code></td>
                            <td><code>{{ bundle_config.project is defined and bundle_config.project is not null and bundle_config.project != '' ? bundle_config.project : '∅' }}</code></td>
                        </tr>
                        <tr>
                            <td><code>locales</code></td>
                            <td>
                                {% if bundle_config.locales is defined and bundle_config.locales is iterable and bundle_config.locales is not empty %}
                                    <code>{{ bundle_config.locales|join(', ') }}</code>
                                {% else %}
                                    <span class="text-muted">[]</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><code>default_locale</code></td>
                            <td><code>{{ bundle_config.default_locale is defined and bundle_config.default_locale is not null and bundle_config.default_locale != '' ? bundle_config.default_locale : '∅' }}</code></td>
                        </tr>
                        <tr>
                            <td><code>doctrine.connection</code></td>
                            <td><code>{{ bundle_config.doctrine.connection|default('default') }}</code></td>
                        </tr>
                        <tr>
                            <td><code>doctrine.table_prefix</code></td>
                            <td><code>{{ bundle_config.doctrine.table_prefix|default('') != '' ? bundle_config.doctrine.table_prefix : '∅' }}</code></td>
                        </tr>
                        <tr>
                            <td><code>cache.ttl</code></td>
                            <td><code>{{ bundle_config.cache.ttl|default('∅') }}</code></td>
                        </tr>
                        <tr>
                            <td><code>cache.pool</code></td>
                            <td><code>{{ bundle_config.cache.pool|default('∅') }}</code></td>
                        </tr>
                        <tr>
                            <td><code>api.enabled</code></td>
                            <td><code>{{ bundle_config.api.enabled is defined ? (bundle_config.api.enabled ? 'true' : 'false') : '∅' }}</code></td>
                        </tr>
                        <tr>
                            <td><code>api.path_prefix</code></td>
                            <td><code>{{ bundle_config.api.path_prefix|default('∅') }}</code></td>
                        </tr>
                        <tr>
                            <td><code>dashboard.enabled</code></td>
                            <td><code>{{ bundle_config.dashboard.enabled is defined ? (bundle_config.dashboard.enabled ? 'true' : 'false') : '∅' }}</code></td>
                        </tr>
                        <tr>
                            <td><code>dashboard.required_role</code></td>
                            <td><code>{{ bundle_config.dashboard.required_role|default('∅') }}</code></td>
                        </tr>
                        <tr>
                            <td><code>dashboard.layout_template</code></td>
                            <td><code>{{ bundle_config.dashboard.layout_template|default('∅') }}</code></td>
                        </tr>
                        <tr>
                            <td><code>dashboard.path_prefix</code></td>
                            <td><code>{{ bundle_config.dashboard.path_prefix|default('∅') }}</code></td>
                        </tr>
                    </tbody>
                </table>

                <h3>Raw bundle config (merged)</h3>
                {% if bundle_config is empty %}
                    <p class="text-muted">No bundle config snapshot available.</p>
                {% else %}
                    <pre class="sf-dump">{{ bundle_config|json_encode(448) }}</pre>
                {% endif %}
            </div>
        </div>

        <div class="tab" id="nowo-dm-tab-permission-checks">
            <h3 class="tab-title">
                Permission checks
                <span class="badge">{{ permission_checks|length }}</span>
            </h3>
            <div class="tab-content">
                <h2>Permission checker results per menu link</h2>
                {% if permission_checks is empty %}
                    <p class="text-muted">No permission checks were recorded for this request.</p>
                {% else %}
                    <table class="sf-table" id="nowo-permission-checks-table">
                        <thead>
                            <tr>
                                <th>
                                    <button type="button" class="btn-link" data-sort-key="menu_link" style="border:0;background:none;padding:0;cursor:pointer;">
                                        Menu + Link
                                    </button>
                                </th>
                                <th>
                                    <button type="button" class="btn-link" data-sort-key="checker_pair" style="border:0;background:none;padding:0;cursor:pointer;">
                                        Permission key / Resolved checker
                                    </button>
                                </th>
                                <th>
                                    <button type="button" class="btn-link" data-sort-key="result" style="border:0;background:none;padding:0;cursor:pointer;">
                                        Result
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in permission_checks %}
                                {% if row.item_type == 'link' %}
                                    <tr>
                                        {% set linkRef = row.route_name ?: (row.external_url ?: '') %}
                                        <td data-sort-value="{{ row.menu_code|lower ~ ' ' ~ row.label|default('')|lower ~ ' ' ~ linkRef|lower }}">
                                            <div class="text-muted"><code>{{ row.menu_code }}</code></div>
                                            <div><strong>{{ row.label|default('—')|e }}</strong></div>
                                            {% if row.route_name %}
                                                <div class="text-muted"><code>{{ row.route_name }}</code></div>
                                            {% elseif row.external_url %}
                                                <div class="text-muted"><code>{{ row.external_url }}</code></div>
                                            {% endif %}
                                        </td>
                                        <td data-sort-value="{{ row.permission_key|default('')|lower ~ ' ' ~ row.checker_resolved|lower }}">
                                            <div>
                                                <span class="text-muted">Permission key:</span>
                                                {% if row.permission_key %}
                                                    <code>{{ row.permission_key }}</code>
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </div>
                                            <div>
                                                <span class="text-muted">Resolved:</span>
                                                <code>{{ row.checker_resolved }}</code>
                                            </div>
                                            {% if row.checker_fallback %}
                                                <span class="sf-toolbar-status sf-toolbar-status-yellow">fallback</span>
                                            {% endif %}
                                        </td>
                                        <td data-sort-value="{{ row.result ? '1' : '0' }}">
                                            {% if row.result %}
                                                <span class="sf-toolbar-status sf-toolbar-status-green">ALLOW</span>
                                            {% else %}
                                                <span class="sf-toolbar-status sf-toolbar-status-red">DENY</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                    <script>
                        (function () {
                            var table = document.getElementById('nowo-permission-checks-table');
                            if (!table) return;
                            var tbody = table.querySelector('tbody');
                            if (!tbody) return;

                            var keyToIndex = {
                                menu_link: 0,
                                checker_pair: 1,
                                result: 2
                            };

                            var sortState = {};
                            table.querySelectorAll('[data-sort-key]').forEach(function (btn) {
                                btn.addEventListener('click', function () {
                                    var key = btn.getAttribute('data-sort-key') || '';
                                    var index = keyToIndex[key];
                                    if (index === undefined) return;
                                    sortState[key] = !(sortState[key] ?? false);
                                    var asc = sortState[key];
                                    var rows = Array.from(tbody.querySelectorAll('tr'));
                                    rows.sort(function (a, b) {
                                        var aCell = a.children[index];
                                        var bCell = b.children[index];
                                        var av = (aCell?.getAttribute('data-sort-value') || aCell?.textContent || '').trim().toLowerCase();
                                        var bv = (bCell?.getAttribute('data-sort-value') || bCell?.textContent || '').trim().toLowerCase();
                                        if (av < bv) return asc ? -1 : 1;
                                        if (av > bv) return asc ? 1 : -1;
                                        return 0;
                                    });
                                    rows.forEach(function (row) { tbody.appendChild(row); });
                                });
                            });
                        })();
                    </script>
                {% endif %}
            </div>
        </div>
    </div>
    <script>
        (function () {
            var tabsRoot = document.querySelector('.sf-tabs');
            if (!tabsRoot) return;
            var tabs = Array.from(tabsRoot.querySelectorAll('.tab[id^="nowo-dm-tab-"]'));
            if (tabs.length === 0) return;

            tabs.forEach(function (tab) {
                var title = tab.querySelector('.tab-title');
                if (!title) return;
                title.addEventListener('click', function () {
                    if (window.location.hash !== '#' + tab.id) {
                        history.replaceState(null, '', '#' + tab.id);
                    }
                });
            });

            var hash = window.location.hash || '';
            if (!hash.startsWith('#nowo-dm-tab-')) return;
            var target = tabsRoot.querySelector(hash);
            if (!target) return;
            var targetTitle = target.querySelector('.tab-title');
            if (targetTitle) {
                targetTitle.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
            }
        })();
    </script>
{% endblock %}

{% macro tree_summary(items, depth) %}
    {% set depth = depth|default(0) %}
    {% if items is defined and items is iterable and items|length > 0 %}
        <ul class="menu-tree-summary" style="margin: 0; padding-left: {{ 0.25 + depth }}rem; list-style: disc;">
            {% for node in items %}
                <li>
                    <span class="badge badge-secondary">{{ node.type }}</span>
                    {% if node.icon|default('') != '' %}
                        <code class="sf-dump-str" title="icon">{{ node.icon|e }}</code>
                    {% endif %}
                    {{ node.label|default('—')|e }}
                    {% if node.children_count > 0 %}
                        <span class="text-muted">({{ node.children_count }})</span>
                        {{ _self.tree_summary(node.children, depth + 0.25) }}
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endmacro %}
