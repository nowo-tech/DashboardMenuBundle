{% if nowo_dashboard_ux_autocomplete_available|default(false) %}
{% form_theme form '@SymfonyUXAutocomplete/autocomplete_form_theme.html.twig' %}
{% endif %}
{% set _section_focus = sectionFocus|default('') %}
{% set _show_basic = form.basic is defined and (_section_focus == '' or _section_focus == 'basic' or _section_focus == 'identity') %}
{% set _show_icon = form.icon is defined and (_section_focus == '' or _section_focus == 'icon' or _section_focus == 'identity') %}
{% set _show_config = form.config is defined and (_section_focus == 'config' or (_section_focus == '' and isEdit)) %}
<div {{ attributes }}>
    {% if app.debug %}
        <div id="dm-livecomponent-debug"
             class="d-none"
             data-php-item-id="{{ this.itemId }}"
             data-php-item-type="{{ this.getItemType() }}"
             data-php-link-type="{{ this.getLinkType() }}"
             data-php-show-link-fields="{{ this.showLinkFields() ? '1' : '0' }}"
             data-php-show-service-fields="{{ this.showServiceLinkFields() ? '1' : '0' }}"
             data-php-show-route-fields="{{ this.showRouteFields() ? '1' : '0' }}"
             data-php-show-external-url="{{ this.showExternalUrlField() ? '1' : '0' }}"
             data-php-item-has-children="{{ this.itemHasChildren ? '1' : '0' }}"
             data-php-translations-count="{{ this.getTranslationsDebug()|length }}"
             data-php-translations-keys="{{ this.getTranslationsKeysDebug() }}"
             data-php-translations-json="{{ this.getTranslationsDebug()|json_encode|e('html_attr') }}"
             data-php-locale-fields-json="{{ this.getLocaleFieldValuesDebug()|json_encode|e('html_attr') }}"
        ></div>
    {% endif %}
    {#
     # Re-render the LiveComponent only when "itemType" changes.
     # This prevents wiping in-progress translation inputs when you switch fields.
    #}
    {{ form_start(form, {
        method: 'POST',
        action: this.actionUrl,
        attr: {
            class: 'form form-vertical',
            'data-model': 'on(change)|*',
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'save',
        }
    }) }}
        {% if _section_focus != '' %}
            <input type="hidden" name="_section" value="{{ _section_focus }}">
        {% endif %}
        {% if _show_basic %}
        <div id="item_basic_section" class="mb-2">
            {% set formName = form.vars.name %}
            <h6 class="text-muted mb-2">
                <i class="bi bi-pencil" aria-hidden="true"></i>
                {{ 'form.menu_item_type.section_basic'|trans({}, 'NowoDashboardMenuBundle') }}
            </h6>
            {% if this.getItemType() == 'divider' %}
                <p class="form-text text-muted small mb-2">{{ 'form.menu_item_type.divider_label_hint'|trans({}, 'NowoDashboardMenuBundle') }}</p>
            {% endif %}
            <div>
                <div class="row">
                    {{ form_row(form.basic.label, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.basic.label' } }) }}
                </div>
                {% if isEdit and locales is not empty %}
                    <div class="row mb-2">
                        {% for locale in locales %}
                            {% set fieldName = 'label_' ~ locale %}
                            {% if attribute(form.basic, fieldName) is defined %}
                                {% set inputAttr = { 'data-model': 'on(change)|' ~ formName ~ '.basic.' ~ fieldName } %}
                                <div class="col-md-6">
                                    {{ form_row(attribute(form.basic, fieldName), { attr: inputAttr }) }}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        {% if _show_icon %}
        <div id="item_icon_section" class="mb-2">
            {% set formName = form.vars.name %}
            <h6 class="text-muted mb-2">
                <i class="bi bi-image" aria-hidden="true"></i>
                {{ 'form.menu_item_type.section_icon'|trans({}, 'NowoDashboardMenuBundle') }}
            </h6>
            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.icon.itemType, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.icon.itemType' } }) }}
                </div>
                {% set positionAttr = { 'data-model': 'on(change)|' ~ formName ~ '.icon.position' } %}
                {% if not isEdit %}
                    {% set positionAttr = positionAttr|merge({ 'disabled': 'disabled' }) %}
                {% endif %}
                <div class="col-md-6 {{ isEdit ? '' : 'd-none' }}">
                    {{ form_row(form.icon.position, { attr: positionAttr }) }}
                </div>
            </div>

            {% set iconAttr = { 'data-model': 'on(change)|' ~ formName ~ '.icon.icon' } %}
            {% if not isEdit %}
                {% set iconAttr = iconAttr|merge({ 'disabled': 'disabled' }) %}
            {% endif %}
            <div class="{{ isEdit ? '' : 'd-none' }}">
                {{ form_row(form.icon.icon, { attr: iconAttr }) }}
            </div>
        </div>
        {% endif %}

        {% if _show_config %}
        <div id="item_config_section" class="mb-2">
            {% if _show_basic %}<hr class="my-3">{% endif %}
            {% set formName = form.vars.name %}
            <h6 class="text-muted mb-2">
                <i class="bi bi-gear" aria-hidden="true"></i>
                {{ 'form.menu_item_type.section_config'|trans({}, 'NowoDashboardMenuBundle') }}
            </h6>
            {% if form.config.parent is defined %}
                {% if this.showParentField() %}
                    {{ form_row(form.config.parent) }}
                {% else %}
                    <div class="d-none">{{ form_row(form.config.parent) }}</div>
                {% endif %}
            {% endif %}
            {% if form.config.sectionCollapsible is defined %}
                {% if this.showSectionCollapsibleField() %}
                    {% set formName = form.vars.name %}
                    {{ form_row(form.config.sectionCollapsible, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.sectionCollapsible' } }) }}
                {% else %}
                    <div class="d-none">{{ form_row(form.config.sectionCollapsible) }}</div>
                {% endif %}
            {% endif %}
            <div class="row">
                {% if this.showLinkFields() and form.config.linkType is defined %}
                    <div class="col-md-6">{{ form_row(form.config.linkType, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.linkType' } }) }}</div>
                {% endif %}
            </div>
            {% if this.showServiceLinkFields() and form.config.linkResolver is defined %}
                <div class="mb-2" id="item_service_link_block">
                    {{ form_row(form.config.linkResolver, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.linkResolver' } }) }}
                    {% if form.config.routeParams is defined %}
                        <small class="form-text text-muted d-block mb-2">{{ 'form.menu_item_type.link_resolver.route_params_hint'|trans({}, 'NowoDashboardMenuBundle') }}</small>
                    {% endif %}
                </div>
            {% endif %}
            {% if this.showLinkFields() and form.config.linkType is defined %}
                <div class="mb-2" id="item_classic_link_block">
                    {% if form.config.routeName is defined %}
                    <div class="mb-2 {{ not this.showRouteFields() ? 'd-none' : '' }}" id="route_name_row">
                        {{ form_row(form.config.routeName, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.routeName' } }) }}
                    </div>
                    {% endif %}
                </div>
                {% if form.config.externalUrl is defined %}
                <div class="mb-2 {{ not this.showExternalUrlField() ? 'd-none' : '' }}" id="item_external_link_block">
                    {{ form_row(form.config.externalUrl, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.externalUrl' } }) }}
                </div>
                {% endif %}
            {% endif %}
            {% if (this.showLinkFields() or this.showServiceLinkFields()) and form.config.routeParams is defined %}
                <div
                    class="mb-2 {% if this.showLinkFields() and not this.showRouteFields() %}d-none{% endif %}"
                    id="route_fields"
                >
                    {{ form_row(form.config.routeParams, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.routeParams' } }) }}
                    {% if this.showRouteFields() %}
                        {% set suggested = this.suggestedRouteParams %}
                        {% if suggested is not empty %}
                            <small class="form-text text-muted d-block mt-1">{{ 'Suggested:'|trans({}, 'NowoDashboardMenuBundle') }} {{ suggested|json_encode(2) }}</small>
                        {% endif %}
                    {% endif %}
                    <small class="form-text text-muted d-none mt-1" id="route_params_hint" aria-hidden="true"></small>
                </div>
            {% endif %}
            {% if (this.showLinkFields() or this.showServiceLinkFields()) and form.config.targetBlank is defined %}
                {{ form_row(form.config.targetBlank, { row_attr: { class: 'form-check ms-0 mb-1' }, attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.targetBlank' } }) }}
            {% elseif not this.showServiceLinkFields() %}
                <div class="d-none">
                    {% if form.config.linkType is defined %}{{ form_row(form.config.linkType, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.linkType' } }) }}{% endif %}
                    {% if form.config.routeName is defined %}{{ form_row(form.config.routeName, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.routeName' } }) }}{% endif %}
                    {% if form.config.routeParams is defined %}{{ form_row(form.config.routeParams, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.routeParams' } }) }}{% endif %}
                    {% if form.config.externalUrl is defined %}{{ form_row(form.config.externalUrl, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.externalUrl' } }) }}{% endif %}
                    {% if form.config.targetBlank is defined %}{{ form_row(form.config.targetBlank, { row_attr: { class: 'form-check ms-0 mb-1' }, attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.targetBlank' } }) }}{% endif %}
                    {% if form.config.linkResolver is defined %}
                        {{ form_row(form.config.linkResolver, { attr: { 'data-model': 'on(change)|' ~ formName ~ '.config.linkResolver' } }) }}
                    {% endif %}
                </div>
            {% endif %}
            {% if form.config.permissionKeys is defined %}
                {{ form_row(form.config.permissionKeys) }}
            {% else %}
                {{ form_row(form.config.permissionKey) }}
            {% endif %}
            {{ form_row(form.config.isUnanimous, { row_attr: { class: 'form-check ms-0 mb-1' } }) }}
        </div>
        {% endif %}
        {{ form_rest(form) }}
        <button
            type="submit"
            class="btn btn-primary"
            data-action="live#action:prevent"
            data-live-action-param="save"
        >
            {{ (isEdit ? 'dashboard.update' : 'dashboard.create')|trans({}, 'NowoDashboardMenuBundle') }}
        </button>
    {{ form_end(form) }}
</div>
