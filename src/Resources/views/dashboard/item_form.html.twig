{% extends nowo_dashboard_layout_template|default('@NowoDashboardMenuBundle/dashboard/layout.html.twig') %}

{% block dashboard_title %}{{ (is_edit ? 'dashboard.edit_item' : 'dashboard.new_item')|trans({}, 'NowoDashboardMenuBundle') }}{% endblock %}

{% block nowo_dashboard_menu_content %}
    {% form_theme form '@SymfonyUXAutocomplete/autocomplete_form_theme.html.twig' %}
    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger">{{ msg }}</div>
    {% endfor %}

    <p>
        <a href="{{ path(dashboard_show_route|default(dashboard_routes.show|default('nowo_dashboard_menu_dashboard_show')), { id: menu.id }) }}" class="btn btn-link text-decoration-none">← {{ menu.code }}</a>
    </p>

    {{ form_start(form, { attr: { class: 'form form-vertical' } }) }}
        <div class="row">
            <div class="mb-3">
                <h6 class="text-muted mb-2">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                    {{ 'form.menu_item_type.section_basic'|trans({}, 'NowoDashboardMenuBundle') }}
                </h6>
                <div class="col-md-6 mb-3">{{ form_row(form.basic.itemType) }}</div>
                <div class="col-md-6 mb-3">{{ form_row(form.basic.icon) }}</div>
                <div id="item_basic_label_icon_fields" class="mb-3">
                    {{ form_row(form.basic.label) }}
                    {% if locales is defined and locales is not empty %}
                        {% for locale in locales %}
                            {% set fieldName = 'label_' ~ locale %}
                            {% if attribute(form.basic, fieldName) is defined %}
                                <div class="col-md-6">{{ form_row(attribute(form.basic, fieldName)) }}</div>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            {% if form.config is defined %}
            <div class="mb-3">
                <h6 class="text-muted mb-2">
                    <i class="bi bi-gear" aria-hidden="true"></i>
                    {{ 'form.menu_item_type.section_config'|trans({}, 'NowoDashboardMenuBundle') }}
                </h6>
                {% if form.config.parent is defined %}
                    <div id="item_parent_field">{{ form_row(form.config.parent) }}</div>
                {% endif %}
                <div class="col-md-6">{{ form_row(form.config.position) }}</div>
                <div id="item_link_fields" data-item-has-children="{{ item_has_children|default(false) ? 'true' : 'false' }}">
                    {{ form_row(form.config.linkType) }}
                    <div id="route_fields">
                        {{ form_row(form.config.routeName) }}
                        {{ form_row(form.config.routeParams) }}
                        <small class="form-text text-muted d-block mt-1" id="route_params_hint"></small>
                    </div>
                    <div id="external_field" style="display: none;">{{ form_row(form.config.externalUrl) }}</div>
                    {{ form_row(form.config.targetBlank) }}
                </div>
                {{ form_row(form.config.permissionKey) }}
            </div>
            {% endif %}
        </div>
        {{ form_rest(form) }}
        <button type="submit" class="btn btn-primary">{{ (is_edit ? 'dashboard.update' : 'dashboard.create')|trans({}, 'NowoDashboardMenuBundle') }}</button>
    {{ form_end(form) }}

    <script>
    window.__nowoDashboardMenuConfig = Object.assign(window.__nowoDashboardMenuConfig || {}, {
        appRoutes: {{ app_routes|json_encode|raw }}
    });
    </script>
{% endblock %}
