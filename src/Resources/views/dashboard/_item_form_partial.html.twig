{% if nowo_dashboard_ux_autocomplete_available|default(false) %}
{% form_theme form '@SymfonyUXAutocomplete/autocomplete_form_theme.html.twig' %}
{% endif %}
{% set _section_focus = section_focus|default('') %}
{% set _show_translations = show_translations|default(is_edit|default(false)) %}
{# Pencil / Add item: only definition. Gear: only configuration. Full edit: both if available. #}
{% set _show_basic = form.basic is defined and (_section_focus == '' or _section_focus == 'basic' or _section_focus == 'identity') %}
{% set _show_icon = form.icon is defined and (_section_focus == '' or _section_focus == 'icon' or _section_focus == 'identity') %}
{% set _show_config = form.config is defined and (_section_focus == 'config' or (_section_focus == '' and is_edit|default(false))) %}
<div id="modal-item-form-container" data-app-routes="{{ app_routes|default({})|json_encode|e('html_attr') }}" data-item-has-children="{{ item_has_children|default(false) ? 'true' : 'false' }}" data-section-focus="{{ _section_focus }}">
{{ form_start(form) }}
    {% if _section_focus != '' %}
        <input type="hidden" name="_section" value="{{ _section_focus }}">
    {% endif %}
    {% if _show_basic %}
    <div id="item_basic_section" class="mb-2">
        <h6 class="text-muted mb-2">
            <i class="bi bi-pencil" aria-hidden="true"></i>
            {{ 'form.menu_item_type.section_basic'|trans({}, 'NowoDashboardMenuBundle') }}
        </h6>
        <div id="item_basic_label_icon_fields" class="mb-2">
            {{ form_row(form.basic.label, { label_attr: { class: 'form-label' }, row_attr: { class: 'mb-2' } }) }}
            {% if _show_translations and locales is defined and locales is not empty %}
                <div class="row">
                    {% for locale in locales %}
                        {% set fieldName = 'label_' ~ locale %}
                        {% if attribute(form.basic, fieldName) is defined %}
                            <div class="col-md-6">
                                {{ form_row(attribute(form.basic, fieldName), { label_attr: { class: 'form-label' } }) }}
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if _show_icon %}
    <div id="item_icon_section" class="mb-2">
        <h6 class="text-muted mb-2">
            <i class="bi bi-image" aria-hidden="true"></i>
            {{ 'form.menu_item_type.section_icon'|trans({}, 'NowoDashboardMenuBundle') }}
        </h6>
        {{ form_row(form.icon.itemType, { label_attr: { class: 'form-label' } }) }}
        <div class="{{ is_edit|default(false) ? '' : 'd-none' }}">
            {% set positionAttr = {} %}
            {% if not is_edit|default(false) %}
                {% set positionAttr = positionAttr|merge({ 'disabled': 'disabled' }) %}
            {% endif %}
            {{ form_row(form.icon.position, { label_attr: { class: 'form-label' }, attr: positionAttr }) }}

            {% set iconAttr = {} %}
            {% if not is_edit|default(false) %}
                {% set iconAttr = iconAttr|merge({ 'disabled': 'disabled' }) %}
            {% endif %}
            {{ form_row(form.icon.icon, { label_attr: { class: 'form-label' }, attr: iconAttr }) }}
        </div>
    </div>
    {% endif %}

    {% if _show_config %}
    <div id="item_config_section" class="mb-2">
        {% if _show_basic %}<hr class="my-3">{% endif %}
        <h6 class="text-muted mb-2">
            <i class="bi bi-gear" aria-hidden="true"></i>
            {{ 'form.menu_item_type.section_config'|trans({}, 'NowoDashboardMenuBundle') }}
        </h6>
        {% if form.config.parent is defined %}
        <div class="mb-2" id="item_parent_field">
            {{ form_row(form.config.parent, { label_attr: { class: 'form-label' } }) }}
        </div>
        {% endif %}
        <div id="item_link_fields" data-item-has-children="{{ item_has_children|default(false) ? 'true' : 'false' }}">
            {{ form_row(form.config.linkType, { label_attr: { class: 'form-label' }, row_attr: { class: 'mb-2' } }) }}
            <div class="mb-2" id="route_fields">
                {{ form_row(form.config.routeName, { label_attr: { class: 'form-label' } }) }}
                {{ form_row(form.config.routeParams, { label_attr: { class: 'form-label mt-2' } }) }}
                <small class="form-text text-muted d-block mt-1" id="route_params_hint"></small>
            </div>
            <div class="mb-2" id="external_field" style="display: none;">
                {{ form_row(form.config.externalUrl, { label_attr: { class: 'form-label' } }) }}
            </div>
            <div class="mb-2">
                {{ form_row(form.config.targetBlank, { label_attr: { class: 'form-check-label' }, row_attr: { class: 'form-check ms-0 mb-1' } }) }}
            </div>
        </div>
        <div class="mb-2">
            {% if form.config.permissionKeys is defined %}
                {{ form_row(form.config.permissionKeys, { label_attr: { class: 'form-label' } }) }}
            {% else %}
                {{ form_row(form.config.permissionKey, { label_attr: { class: 'form-label' } }) }}
            {% endif %}
            {{ form_row(form.config.isUnanimous, { row_attr: { class: 'form-check ms-0 mb-1' } }) }}
        </div>
    </div>
    {% endif %}
    {{ form_rest(form) }}
    <button type="submit" class="btn btn-primary">{{ (is_edit|default(false) ? 'dashboard.update' : 'dashboard.create')|trans({}, 'NowoDashboardMenuBundle') }}</button>
{{ form_end(form) }}
</div>
