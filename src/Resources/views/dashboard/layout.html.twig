<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block dashboard_title %}{{ 'dashboard.title'|trans }}{% endblock %} — {{ 'dashboard.title_suffix'|trans }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path(dashboard_routes.index|default('nowo_dashboard_menu_dashboard_index')) }}">{{ 'dashboard.title'|trans }}</a>
        </div>
    </nav>
    <main class="container-fluid py-4">
        {% block dashboard_body %}{% endblock %}
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    window.dashboardMenuI18n = {
        loading: {{ 'dashboard.loading'|trans|json_encode|raw }},
        errorLoadingForm: {{ 'dashboard.error_loading_form'|trans|json_encode|raw }},
        deleteMenuConfirm: {{ 'dashboard.delete_menu_confirm'|trans|json_encode|raw }},
        editItem: {{ 'dashboard.edit_item'|trans|json_encode|raw }},
        addItem: {{ 'dashboard.add_item'|trans|json_encode|raw }},
        deleteItemConfirm: {{ 'dashboard.delete_item_confirm'|trans|json_encode|raw }}
    };
    </script>
</body>
</html>
