<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block dashboard_title %}{{ 'dashboard.title'|trans({}, 'NowoDashboardMenuBundle') }}{% endblock %} — {{ 'dashboard.title_suffix'|trans({}, 'NowoDashboardMenuBundle') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block dashboard_head %}
    <style>
        {# Tom Select dropdown appended to body must stack above Bootstrap 5 modals (z-index 1055). #}
        body > .ts-dropdown { z-index: 1060; }
    </style>
    {% endblock %}
    {% if stimulus_script_url is defined and stimulus_script_url %}
    <script type="module" src="{{ (stimulus_script_url starts with 'http') ? stimulus_script_url : asset(stimulus_script_url) }}"></script>
    {% endif %}
    {% if icon_selector_script_url is defined and icon_selector_script_url %}
    <script src="{{ (icon_selector_script_url starts with 'http') ? icon_selector_script_url : asset(icon_selector_script_url) }}" defer></script>
    {% endif %}
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path(dashboard_routes.index|default('nowo_dashboard_menu_dashboard_index')) }}">{{ 'dashboard.title'|trans({}, 'NowoDashboardMenuBundle') }}</a>
        </div>
    </nav>
    <main class="container-fluid py-4">
        {% block nowo_dashboard_menu_content %}{% endblock %}
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block dashboard_scripts %}{% endblock %}
    <script src="{{ asset('bundles/nowodashboardmenu/js/dashboard.js') }}" defer></script>
    <script>
    {% if icon_selector_script_url is defined and icon_selector_script_url %}
    window.dashboardMenuIconSelectorScriptUrl = {{ (icon_selector_script_url starts with 'http') ? icon_selector_script_url : asset(icon_selector_script_url) |json_encode|raw }};
    {% endif %}
    window.dashboardMenuI18n = {
        loading: {{ 'dashboard.loading'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        errorLoadingForm: {{ 'dashboard.error_loading_form'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        deleteMenuConfirm: {{ 'dashboard.delete_menu_confirm'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        editItem: {{ 'dashboard.edit_item'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        editConfig: {{ 'dashboard.edit_config'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        editMenu: {{ 'dashboard.edit_menu'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        addItem: {{ 'dashboard.add_item'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }},
        deleteItemConfirm: {{ 'dashboard.delete_item_confirm'|trans({}, 'NowoDashboardMenuBundle')|json_encode|raw }}
    };
    </script>
</body>
</html>
