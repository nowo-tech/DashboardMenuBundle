{% set _section_focus = section_focus|default('') %}
{# Definition modal: only form.definition. Configuration modal: only form.config. New menu / full edit: both if available. #}
{% set _show_definition = form.definition is defined and (_section_focus == '' or _section_focus == 'basic') %}
{% set _show_config = form.config is defined and (_section_focus == 'config' or (_section_focus == '' and is_edit|default(false))) %}
{{ form_start(form, { attr: { class: 'form form-vertical' } }) }}
    {% if _section_focus != '' %}
        <input type="hidden" name="_section" value="{{ _section_focus }}">
    {% endif %}
    <div class="row mb-2">
        {% if _show_definition %}
        <div id="menu_definition_section">
        <p class="text-muted small mb-2">
            <span class="bi bi-pencil-fill me-1" aria-hidden="true"></span>
            {{ 'form.menu_type.section_definition'|trans({}, 'NowoDashboardMenuBundle') }}
        </p>
        {% for field in form.definition %}
            {{ form_row(field) }}
        {% endfor %}
        </div>
        {% endif %}

        {% if _show_config %}
        <div id="menu_config_section">
        {% if _show_definition %}<hr class="my-3">{% endif %}
        <p class="text-muted small mb-2">
            <span class="bi bi-gear-fill me-1" aria-hidden="true"></span>
            {{ 'form.menu_type.section_config'|trans({}, 'NowoDashboardMenuBundle') }}
        </p>
        {% for field in form.config %}
            {% if field.vars.name == 'classMenu' %}
                <hr class="my-3">
                <p class="text-muted small mb-2">{{ 'form.menu_type.css_section_heading'|trans({}, 'NowoDashboardMenuBundle') }}</p>
            {% endif %}
            {{ form_row(field) }}
        {% endfor %}
        </div>
        {% endif %}
    </div>
    <button type="submit" class="btn btn-primary">{{ (is_edit|default(false) ? 'dashboard.update' : 'dashboard.create')|trans({}, 'NowoDashboardMenuBundle') }}</button>
{{ form_end(form) }}
