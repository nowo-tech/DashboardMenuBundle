<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         executionOrder="depends,defects"
         beStrictAboutOutputDuringTests="true"
         failOnRisky="true"
>
    <testsuites>
        <testsuite name="unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <directory>demo</directory>
            <!-- Google Translate REST CLI and dashboard HTTP UI: manual/integration-only; excluded from aggregate Clover gate. -->
            <file>src/Command/GoogleSyncTranslationsCommand.php</file>
            <directory>src/Controller/Dashboard</directory>
            <directory>src/DependencyInjection/Compiler</directory>
            <file>src/Repository/MenuItemRepository.php</file>
            <file>src/Service/MenuTreeLoader.php</file>
            <file>src/Form/MenuItemConfigType.php</file>
            <file>src/Entity/MenuItem.php</file>
            <file>src/Form/MenuItemIconType.php</file>
            <file>src/Command/GenerateDashboardMenuMigrationCommand.php</file>
            <file>src/DependencyInjection/Configuration.php</file>
        </exclude>
    </source>
</phpunit>
