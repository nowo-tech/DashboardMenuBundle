parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
        # Form types reference Symfony Form/Validator; analyse when bundle is used in an app
        - src/Form/*
    bootstrapFiles:
        - vendor/autoload.php
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Symfony Form/Validator: classes in vendor not resolved when analysing bundle alone
        - identifier: class.notFound
          path: src/Controller/Dashboard/*.php
        - identifier: class.notFound
          path: src/Controller/Api/*.php
        - identifier: argument.type
          path: src/Controller/Dashboard/MenuDashboardController.php
        - identifier: argument.type
          path: src/Controller/Dashboard/MenuDashboardController.php
          message: '~CopyMenuType~'
        # Tree shape when passing through helpers
        - identifier: argument.type
          path: src/Service/MenuTreeLoader.php
        - identifier: argument.type
          path: src/Service/CurrentRouteTreeDecorator.php
        - identifier: argument.type
          path: src/Controller/Api/MenuApiController.php
        # Árbol recursivo: children tiene la misma forma que nodes
        - identifier: argument.type
          path: src/DataCollector/DashboardMenuDataCollector.php
          message: '~summarizeTree~'
        # Tests: mocks PHPUnit, tipos genéricos y assertions
        - identifier: assign.propertyType
          path: tests/*
        - identifier: argument.type
          path: tests/*
        - identifier: missingType.iterableValue
          path: tests/*
        - identifier: staticMethod.alreadyNarrowedType
          path: tests/*
        - identifier: method.notFound
          path: tests/*
        - identifier: missingType.generics
          path: tests/*
        - identifier: missingType.parameter
          path: tests/*
        - identifier: property.onlyWritten
          path: tests/*
        - identifier: method.nonObject
          path: tests/*
        - identifier: offsetAccess.nonOffsetAccessible
          path: tests/*
        - identifier: argument.type
          path: tests/Unit/DependencyInjection/Compiler/*
